# Copy this file to .env and fill in your own values.
# The .env file is gitignored, so your secrets never get committed.

# Hopsworks API key. Grab one from your Hopsworks account under
# Account Settings -> API Keys (give it project + feature store access).
HOPSWORKS_API_KEY=your_api_key_here

# Name of the Hopsworks project you created in the UI.
HOPSWORKS_PROJECT=aqi_predict
